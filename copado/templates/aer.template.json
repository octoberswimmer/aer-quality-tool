{
  "name": "aer",
  "apiname": "aer",
  "type": "Custom",
  "description": "run aer tests in copado quality gate",
  "version": 1,
  "volumeoptions": null,
  "steps": [
    {
      "name": "run aer test",
      "type": "Function",
      "customtype": "Function",
      "config": {
        "functionName": "aer",
        "parameters": [
          {
            "name": "git_json",
            "value": "{$Context.Repository.Credential}"
          },
          {
            "name": "branchesAndFileIdJson",
            "value": "{$Context.Apex.copadoQuality.RetrieveBranchesAndFileIdForPmdScan}"
          },
          {
            "name": "jobExecutionDataJson",
            "value": "{$Context.JobExecution__r.copado__DataJson__c}"
          },
          {
            "name": "aerConfigJson",
            "value": "{$Context.Apex.AerConfigExpression}"
          }
        ]
      }
    }
  ]
}
