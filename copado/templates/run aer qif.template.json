{
  "name": "run aer qif",
  "apiname": "run_aer_qif_1",
  "type": "Custom",
  "description": "run aer tests in copado quality gate",
  "version": 1,
  "volumeoptions": null,
  "steps": [
    {
      "name": "run aer test",
      "type": "Function",
      "customtype": "Function",
      "config": {
        "functionName": "run_aer_qif",
        "parameters": [
          {
            "name": "git_json",
            "value": "{$Context.Repository.Credential}"
          },
          {
            "name": "branchesAndFileIdJson",
            "value": "{$Context.Apex.copadoQuality.RetrieveBranchesAndFileIdForPmdScan}"
          },
          {
            "name": "targetBranch",
            "value": "{$Context.JobExecution__r.DataJson.destinationBranchName}"
          },
          {
            "name": "baseBranch",
            "value": "{$Context.JobExecution__r.DataJson.baseBranch}"
          },
          {
            "name": "jobExecutionDataJson",
            "value": "{$Context.JobExecution__r.DataJson}"
          },
          {
            "name": "source",
            "value": "{$Context.JobExecution__r.DataJson.source}"
          },
          {
            "name": "flags",
            "value": "{$Context.JobExecution__r.DataJson.flags}"
          },
          {
            "name": "defaultNamespace",
            "value": "{$Context.JobExecution__r.DataJson.defaultNamespace}"
          },
          {
            "name": "version",
            "value": "{$Context.JobExecution__r.DataJson.version}"
          }
        ]
      }
    }
  ]
}
